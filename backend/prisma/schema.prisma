generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum RegistrationMemberRole {
  CAPTAIN
  PLAYER
  SUBSTITUTE
  COACH
}

model User {
  id                 String       @id @default(uuid()) @db.Uuid
  firstName          String       @map("first_name")
  lastName           String       @map("last_name")
  email              String
  emailNormalized    String       @unique @map("email_normalized")
  username           String
  usernameNormalized String       @unique @map("username_normalized")
  passwordHash       String       @map("password_hash")
  role               UserRole     @default(user)
  phone              String?
  discordTag         String?      @map("discord_tag")
  lastLoginAt        DateTime?    @map("last_login_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  sessions           Session[]

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model ContactSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@map("contact_submissions")
}

model Tournament {
  id                String             @id @default(uuid()) @db.Uuid
  slug              String             @unique
  title             String
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  teamRegistrations TeamRegistration[]

  @@index([isActive])
  @@map("tournaments")
}

model TeamRegistration {
  id                     String               @id @default(uuid()) @db.Uuid
  tournamentId           String               @map("tournament_id") @db.Uuid
  teamName               String               @map("team_name")
  captainName            String               @map("captain_name")
  captainEmail           String               @map("captain_email")
  captainPhone           String               @map("captain_phone")
  captainDiscord         String               @map("captain_discord")
  captainRiotId          String               @map("captain_riot_id")
  contactEmail           String               @map("contact_email")
  teamLogoName           String?              @map("team_logo_name")
  rulebookAccepted       Boolean              @default(false) @map("rulebook_accepted")
  falsityWarningAccepted Boolean              @default(false) @map("falsity_warning_accepted")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  tournament             Tournament           @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  members                RegistrationMember[]

  @@unique([tournamentId, teamName])
  @@unique([tournamentId, captainEmail])
  @@index([tournamentId])
  @@index([createdAt])
  @@map("team_registrations")
}

model RegistrationMember {
  id             String                 @id @default(uuid()) @db.Uuid
  registrationId String                 @map("registration_id") @db.Uuid
  role           RegistrationMemberRole
  memberOrder    Int                    @map("member_order")
  name           String
  discord        String?
  riotId         String?                @map("riot_id")
  createdAt      DateTime               @default(now()) @map("created_at")
  registration   TeamRegistration       @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([registrationId, role, memberOrder])
  @@index([registrationId])
  @@map("registration_members")
}
