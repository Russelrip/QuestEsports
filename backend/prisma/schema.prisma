generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum RegistrationMemberRole {
  CAPTAIN
  PLAYER
  SUBSTITUTE
  COACH
}

enum TournamentStatus {
  draft
  upcoming
  registration_open
  ongoing
  completed
  cancelled
}

enum TeamRegistrationStatus {
  pending
  approved
  rejected
}

enum RegistrationPaymentStatus {
  unpaid
  pending
  paid
}

enum RegistrationVerificationStatus {
  pending
  verified
  flagged
}

model User {
  id                 String       @id @default(uuid()) @db.Uuid
  firstName          String       @map("first_name")
  lastName           String       @map("last_name")
  email              String
  emailNormalized    String       @unique @map("email_normalized")
  username           String
  usernameNormalized String       @unique @map("username_normalized")
  passwordHash       String       @map("password_hash")
  emailVerified      Boolean      @default(false) @map("email_verified")
  emailVerifiedAt    DateTime?    @map("email_verified_at")
  role               UserRole     @default(user)
  phone              String?
  discordTag         String?      @map("discord_tag")
  lastLoginAt        DateTime?    @map("last_login_at")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")
  sessions           Session[]
  verificationTokens VerificationToken[]
  passwordResetTokens PasswordResetToken[]

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model VerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  lastSeenAt DateTime? @map("last_seen_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model ContactSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([isRead, createdAt])
  @@map("contact_submissions")
}

model Tournament {
  id                String             @id @default(uuid()) @db.Uuid
  slug              String             @unique
  title             String
  game              String
  bannerImageName   String?            @map("banner_image_name")
  shortDescription  String             @map("short_description")
  fullDescription   String             @map("full_description")
  rules             String?
  startDate         DateTime           @map("start_date")
  endDate           DateTime           @map("end_date")
  registrationDeadline DateTime        @map("registration_deadline")
  format            String
  teamSize          Int                @map("team_size")
  maxTeams          Int                @map("max_teams")
  prizePool         String             @map("prize_pool")
  status            TournamentStatus   @default(draft)
  isPublished       Boolean            @default(false) @map("is_published")
  bracketLink       String?            @map("bracket_link")
  contactLink       String?            @map("contact_link")
  isFeatured        Boolean            @default(false) @map("is_featured")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  teamRegistrations TeamRegistration[]
  posters           Poster[]

  @@index([isActive])
  @@index([isPublished, status, startDate])
  @@index([isFeatured, isPublished])
  @@map("tournaments")
}

model TeamRegistration {
  id                     String               @id @default(uuid()) @db.Uuid
  tournamentId           String               @map("tournament_id") @db.Uuid
  teamName               String               @map("team_name")
  captainName            String               @map("captain_name")
  captainEmail           String               @map("captain_email")
  captainPhone           String               @map("captain_phone")
  captainDiscord         String               @map("captain_discord")
  captainRiotId          String               @map("captain_riot_id")
  contactEmail           String               @map("contact_email")
  teamLogoName           String?              @map("team_logo_name")
  status                 TeamRegistrationStatus @default(pending)
  paymentStatus          RegistrationPaymentStatus @default(unpaid) @map("payment_status")
  verificationStatus     RegistrationVerificationStatus @default(pending) @map("verification_status")
  rulebookAccepted       Boolean              @default(false) @map("rulebook_accepted")
  falsityWarningAccepted Boolean              @default(false) @map("falsity_warning_accepted")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  tournament             Tournament           @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  members                RegistrationMember[]

  @@unique([tournamentId, teamName])
  @@unique([tournamentId, captainEmail])
  @@index([tournamentId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, verificationStatus])
  @@map("team_registrations")
}

model RegistrationMember {
  id             String                 @id @default(uuid()) @db.Uuid
  registrationId String                 @map("registration_id") @db.Uuid
  role           RegistrationMemberRole
  memberOrder    Int                    @map("member_order")
  name           String
  discord        String?
  riotId         String?                @map("riot_id")
  createdAt      DateTime               @default(now()) @map("created_at")
  registration   TeamRegistration       @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([registrationId, role, memberOrder])
  @@index([registrationId])
  @@map("registration_members")
}

model ImageAsset {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  description  String?
  category     String
  originalName String?  @map("original_name")
  storedFilename String? @map("stored_filename")
  contentType  String   @map("content_type")
  byteSize     Int?     @map("byte_size")
  data         Bytes?
  createdAt    DateTime @default(now()) @map("created_at")
  posters      Poster[]

  @@index([category, createdAt])
  @@index([createdAt])
  @@map("image_assets")
}

model Poster {
  id            String      @id @default(uuid()) @db.Uuid
  imageAssetId  String      @map("image_asset_id") @db.Uuid
  tournamentId  String?     @map("tournament_id") @db.Uuid
  title         String
  description   String?
  category      String      @default("poster")
  headline      String
  subheadline   String?     @map("subheadline")
  accentColor   String      @default("#7c3aed") @map("accent_color")
  textColor     String      @default("#ffffff") @map("text_color")
  overlayAlign  String      @default("bottom-left") @map("overlay_align")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  imageAsset    ImageAsset  @relation(fields: [imageAssetId], references: [id], onDelete: Cascade)
  tournament    Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)

  @@index([imageAssetId])
  @@index([tournamentId])
  @@index([category, createdAt])
  @@index([createdAt])
  @@map("posters")
}
