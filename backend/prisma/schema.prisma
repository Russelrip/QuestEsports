generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum AuthProvider {
  google
  discord
}

enum RegistrationMemberRole {
  CAPTAIN
  PLAYER
  SUBSTITUTE
  COACH
}

enum TournamentStatus {
  draft
  upcoming
  registration_open
  ongoing
  completed
  cancelled
}

enum TeamRegistrationStatus {
  pending
  approved
  rejected
}

enum RegistrationPaymentStatus {
  unpaid
  pending
  paid
}

enum RegistrationVerificationStatus {
  pending
  verified
  flagged
}

enum TeamMemberInviteStatus {
  pending
  accepted
  declined
}

enum BackgroundJobStatus {
  queued
  processing
  succeeded
  failed
}

model User {
  id                     String            @id @default(uuid()) @db.Uuid
  firstName              String            @map("first_name")
  lastName               String            @map("last_name")
  email                  String
  emailNormalized        String            @unique @map("email_normalized")
  pendingEmail           String?           @map("pending_email")
  pendingEmailNormalized String?           @unique @map("pending_email_normalized")
  username               String
  usernameNormalized     String            @unique @map("username_normalized")
  passwordHash           String            @map("password_hash")
  emailVerified          Boolean           @default(false) @map("email_verified")
  emailVerifiedAt        DateTime?         @map("email_verified_at")
  role                   UserRole          @default(user)
  phone                  String?
  discordTag             String?           @map("discord_tag")
  lastLoginAt            DateTime?         @map("last_login_at")
  failedLoginCount       Int               @default(0) @map("failed_login_count")
  lastFailedLoginAt      DateTime?         @map("last_failed_login_at")
  lockedUntil            DateTime?         @map("locked_until")
  mfaEnabled             Boolean           @default(false) @map("mfa_enabled")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")
  sessions               Session[]
  verificationTokens     VerificationToken[]
  emailChangeTokens      EmailChangeToken[]
  passwordResetTokens PasswordResetToken[]
  mfaCredential          MfaCredential?
  backupCodes            BackupCode[]
  loginChallenges        LoginChallenge[]
  oauthAccounts          OAuthAccount[]
  savedTeams             SavedTeam[]

  @@index([role])
  @@index([createdAt])
  @@index([lockedUntil])
  @@map("users")
}

model VerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailChangeToken {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @map("user_id") @db.Uuid
  nextEmail           String   @map("next_email")
  nextEmailNormalized String   @map("next_email_normalized")
  tokenHash           String   @unique @map("token_hash")
  expiresAt           DateTime @map("expires_at")
  usedAt              DateTime? @map("used_at")
  createdAt           DateTime @default(now()) @map("created_at")
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nextEmailNormalized])
  @@index([expiresAt])
  @@map("email_change_tokens")
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  lastSeenAt DateTime? @map("last_seen_at")
  userAgent  String?   @map("user_agent")
  ipAddress  String?   @map("ip_address")
  rememberMe Boolean   @default(false) @map("remember_me")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model MfaCredential {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  secretCiphertext String   @map("secret_ciphertext")
  enabledAt        DateTime? @map("enabled_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mfa_credentials")
}

model BackupCode {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  codeHash  String    @unique @map("code_hash")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([usedAt])
  @@map("backup_codes")
}

model LoginChallenge {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  rememberMe Boolean   @default(false) @map("remember_me")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("login_challenges")
}

model OAuthAccount {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @map("user_id") @db.Uuid
  provider          AuthProvider
  providerUserId    String       @map("provider_user_id")
  email             String?      @map("email")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

model ContactSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([createdAt])
  @@index([isRead, createdAt])
  @@map("contact_submissions")
}

model Tournament {
  id                String             @id @default(uuid()) @db.Uuid
  slug              String             @unique
  title             String
  game              String
  bannerImageName   String?            @map("banner_image_name")
  shortDescription  String             @map("short_description")
  fullDescription   String             @map("full_description")
  rules             String?
  startDate         DateTime           @map("start_date")
  endDate           DateTime           @map("end_date")
  registrationDeadline DateTime        @map("registration_deadline")
  format            String
  teamSize          Int                @map("team_size")
  maxTeams          Int                @map("max_teams")
  prizePool         String             @map("prize_pool")
  status            TournamentStatus   @default(draft)
  isPublished       Boolean            @default(false) @map("is_published")
  bracketLink       String?            @map("bracket_link")
  contactLink       String?            @map("contact_link")
  isFeatured        Boolean            @default(false) @map("is_featured")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  teamRegistrations TeamRegistration[]
  posters           Poster[]

  @@index([isActive])
  @@index([isPublished, status, startDate])
  @@index([isFeatured, isPublished])
  @@map("tournaments")
}

model TeamRegistration {
  id                     String               @id @default(uuid()) @db.Uuid
  tournamentId           String               @map("tournament_id") @db.Uuid
  teamName               String               @map("team_name")
  captainName            String               @map("captain_name")
  captainEmail           String               @map("captain_email")
  captainPhone           String               @map("captain_phone")
  captainDiscord         String               @map("captain_discord")
  captainRiotId          String               @map("captain_riot_id")
  contactEmail           String               @map("contact_email")
  teamLogoName           String?              @map("team_logo_name")
  status                 TeamRegistrationStatus @default(pending)
  paymentStatus          RegistrationPaymentStatus @default(unpaid) @map("payment_status")
  verificationStatus     RegistrationVerificationStatus @default(pending) @map("verification_status")
  rulebookAccepted       Boolean              @default(false) @map("rulebook_accepted")
  falsityWarningAccepted Boolean              @default(false) @map("falsity_warning_accepted")
  createdAt              DateTime             @default(now()) @map("created_at")
  updatedAt              DateTime             @updatedAt @map("updated_at")
  tournament             Tournament           @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  members                RegistrationMember[]

  @@unique([tournamentId, teamName])
  @@unique([tournamentId, captainEmail])
  @@index([tournamentId])
  @@index([createdAt])
  @@index([status, createdAt])
  @@index([paymentStatus, verificationStatus])
  @@map("team_registrations")
}

model RegistrationMember {
  id             String                 @id @default(uuid()) @db.Uuid
  registrationId String                 @map("registration_id") @db.Uuid
  role           RegistrationMemberRole
  memberOrder    Int                    @map("member_order")
  name           String
  email          String?
  emailNormalized String?               @map("email_normalized")
  discord        String?
  riotId         String?                @map("riot_id")
  createdAt      DateTime               @default(now()) @map("created_at")
  registration   TeamRegistration       @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([registrationId, role, memberOrder])
  @@index([registrationId])
  @@index([emailNormalized])
  @@map("registration_members")
}

model SavedTeam {
  id            String            @id @default(uuid()) @db.Uuid
  captainUserId String            @map("captain_user_id") @db.Uuid
  name          String
  logoName      String?           @map("logo_name")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  captainUser   User              @relation(fields: [captainUserId], references: [id], onDelete: Cascade)
  members       SavedTeamMember[]

  @@unique([captainUserId, name])
  @@index([captainUserId])
  @@index([createdAt])
  @@map("saved_teams")
}

model SavedTeamMember {
  id                String               @id @default(uuid()) @db.Uuid
  teamId            String               @map("team_id") @db.Uuid
  role              RegistrationMemberRole
  memberOrder       Int                  @map("member_order")
  name              String
  email             String
  emailNormalized   String               @map("email_normalized")
  discord           String?
  riotId            String?              @map("riot_id")
  inviteStatus      TeamMemberInviteStatus @default(pending) @map("invite_status")
  inviteTokenHash   String?              @unique @map("invite_token_hash")
  inviteSentAt      DateTime?            @map("invite_sent_at")
  inviteExpiresAt   DateTime?            @map("invite_expires_at")
  inviteRespondedAt DateTime?            @map("invite_responded_at")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  team              SavedTeam            @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, role, memberOrder])
  @@unique([teamId, emailNormalized])
  @@index([teamId])
  @@index([emailNormalized])
  @@index([inviteStatus])
  @@map("saved_team_members")
}

model RateLimitBucket {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  key       String
  count     Int      @default(0)
  resetAt   DateTime @map("reset_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, key])
  @@index([resetAt])
  @@map("rate_limit_buckets")
}

model BackgroundJob {
  id          String              @id @default(uuid()) @db.Uuid
  name        String
  payload     Json
  status      BackgroundJobStatus @default(queued)
  attempts    Int                 @default(0)
  maxAttempts Int                 @default(5) @map("max_attempts")
  availableAt DateTime            @default(now()) @map("available_at")
  lockedAt    DateTime?           @map("locked_at")
  completedAt DateTime?           @map("completed_at")
  failedAt    DateTime?           @map("failed_at")
  lastError   String?             @map("last_error")
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")

  @@index([status, availableAt])
  @@index([lockedAt])
  @@index([createdAt])
  @@map("background_jobs")
}

model ImageAsset {
  id           String   @id @default(uuid()) @db.Uuid
  title        String
  description  String?
  category     String
  originalName String?  @map("original_name")
  storedFilename String? @map("stored_filename")
  contentType  String   @map("content_type")
  byteSize     Int?     @map("byte_size")
  data         Bytes?
  createdAt    DateTime @default(now()) @map("created_at")
  posters      Poster[]

  @@index([category, createdAt])
  @@index([createdAt])
  @@map("image_assets")
}

model Poster {
  id            String      @id @default(uuid()) @db.Uuid
  imageAssetId  String      @map("image_asset_id") @db.Uuid
  tournamentId  String?     @map("tournament_id") @db.Uuid
  title         String
  description   String?
  category      String      @default("poster")
  headline      String
  subheadline   String?     @map("subheadline")
  accentColor   String      @default("#7c3aed") @map("accent_color")
  textColor     String      @default("#ffffff") @map("text_color")
  overlayAlign  String      @default("bottom-left") @map("overlay_align")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  imageAsset    ImageAsset  @relation(fields: [imageAssetId], references: [id], onDelete: Cascade)
  tournament    Tournament? @relation(fields: [tournamentId], references: [id], onDelete: SetNull)

  @@index([imageAssetId])
  @@index([tournamentId])
  @@index([category, createdAt])
  @@index([createdAt])
  @@map("posters")
}
